      "language": "fr",
      "expected_doc_title_contains": ["Port Activity", "financier"],
      "expected_reply_contains": ["2024"],
      "expected_confidence_min": 0.6
    },
    {
      "id": "chiffre-affaires-fr",
      "question": "Quel a été le chiffre d'affaires consolidé de Tanger Med en 2024 ?",
      "language": "fr",
      "expected_doc_title_contains": ["financier", "Key Figures", "Communication financière"],
      "expected_reply_contains": ["2024"],
      "expected_confidence_min": 0.5
    },
    {
      "id": "tanger-med-overview-en",
      "question": "What is Tanger Med?",
      "language": "en",
      "expected_doc_title_contains": ["Brochure", "CSR", "Port Activity"],
      "expected_reply_contains": ["port", "Tanger Med"],
      "expected_confidence_min": 0.5
